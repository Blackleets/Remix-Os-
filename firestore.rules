rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role-based Access Helpers
    function getUserRole(companyId) {
      return get(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + companyId)).data.role;
    }

    function hasRole(companyId, roles) {
      let path = /databases/$(database)/documents/memberships/$(request.auth.uid + '_' + companyId);
      return isSignedIn() && exists(path) && get(path).data.role in roles;
    }

    function isMember(companyId) {
      return isSignedIn() && exists(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + companyId));
    }

    function isMemberAfter(companyId) {
      return isSignedIn() && existsAfter(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + companyId));
    }

    // Production note: once custom claims are deployed, prefer
    // request.auth.token.superAdmin == true over document lookups.
    function hasPlatformAdminClaim() {
      return isSignedIn() && request.auth.token.superAdmin == true;
    }

    function hasPlatformAdminRecord() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/platformAdmins/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/platformAdmins/$(request.auth.uid)).data.active == true &&
             get(/databases/$(database)/documents/platformAdmins/$(request.auth.uid)).data.role == 'super_admin';
    }

    function isPlatformAdmin() {
      return hasPlatformAdminClaim() || hasPlatformAdminRecord();
    }

    // --- Entity Validations ---

    function isValidMembership(data) {
      return data.size() >= 3 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.companyId is string &&
             data.role in ['owner', 'admin', 'staff', 'viewer'] &&
             data.keys().hasAll(['userId', 'companyId', 'role']) &&
             (!('createdAt' in data) || data.createdAt == request.time);
    }

    function isValidNewCompany(data) {
      return data.ownerId is string && data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             // Force the starter plan on creation; paid plans must come from the
             // server-side billing webhook with elevated privileges.
             (!('subscription' in data) || (
               data.subscription.planId == 'starter' &&
               data.subscription.status in ['active', 'trialing']
             ));
    }

    function isValidProduct(data) {
      return data.size() >= 3 &&
             data.companyId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             (!('price' in data) || (data.price is number && data.price >= 0)) &&
             (!('sku' in data) || (data.sku is string && data.sku.size() <= 100));
    }

    function isValidCustomer(data) {
      return data.size() >= 2 &&
             data.companyId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             (!('segment' in data) || data.segment in ["whale", "vip", "regular", "new", "at_risk"]) &&
             (!('totalSpent' in data) || data.totalSpent is number) &&
             (!('totalOrders' in data) || data.totalOrders is number) &&
             (!('lastOrderAt' in data) || data.lastOrderAt == request.time || data.lastOrderAt is timestamp);
    }

    function isValidReminder(data) {
      return data.size() >= 5 &&
             data.companyId is string &&
             data.customerId is string &&
             data.type in ["follow_up", "payment", "order", "reactivation"] &&
             data.status in ["pending", "completed", "dismissed"] &&
             // Accept both legacy string dates and the new Timestamp format.
             (data.dueDate is string || data.dueDate is timestamp);
    }

    function isValidCustomerMessage(data) {
      return data.size() >= 4 &&
             data.companyId is string &&
             data.customerId is string &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 5000 &&
             data.status in ["draft", "ready", "sent"];
    }

    function isValidFeedback(data) {
      return data.userId is string &&
             data.userId == request.auth.uid &&
             data.userEmail is string &&
             data.companyId is string &&
             isMember(data.companyId) &&
             data.companyName is string && data.companyName.size() > 0 && data.companyName.size() <= 200 &&
             data.type in ['bug', 'improvement', 'idea', 'other'] &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 4000 &&
             data.route is string && data.route.size() > 0 && data.route.size() <= 300 &&
             data.status == 'open' &&
             data.createdAt == request.time;
    }

    function isValidBetaFeedbackCreate(data) {
      return data.keys().hasAll([
               'companyId',
               'userId',
               'userEmail',
               'type',
               'severity',
               'title',
               'message',
               'pagePath',
               'status',
               'createdAt',
               'updatedAt'
             ]) &&
             data.companyId is string &&
             data.companyId.size() > 0 &&
             data.companyId.size() <= 128 &&
             data.userId is string &&
             data.userId == request.auth.uid &&
             data.userEmail is string &&
             data.userEmail.size() > 0 &&
             data.userEmail.size() <= 320 &&
             data.type in ['bug', 'idea', 'ux', 'billing', 'copilot', 'other'] &&
             data.severity in ['low', 'medium', 'high', 'critical'] &&
             data.title is string &&
             data.title.size() > 0 &&
             data.title.size() <= 120 &&
             data.message is string &&
             data.message.size() > 0 &&
             data.message.size() <= 3000 &&
             data.pagePath is string &&
             data.pagePath.size() <= 500 &&
             data.status == 'open' &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    // Bounds invoice payloads so a malicious client can't write a huge
    // items[] array or megabyte-long strings that would blow up reads and
    // billing costs for the whole tenant. Optional fields are only checked
    // when present so older shapes keep working.
    function isValidInvoicePayload(data) {
      return data.companyId is string && data.companyId.size() <= 128 &&
             data.customerName is string &&
             data.customerName.size() > 0 && data.customerName.size() <= 200 &&
             data.series is string && data.series.size() <= 12 &&
             data.items is list && data.items.size() <= 200 &&
             data.total is number && data.total >= 0 &&
             data.subtotal is number && data.subtotal >= 0 &&
             data.taxTotal is number && data.taxTotal >= 0 &&
             (!('discountTotal' in data) || (data.discountTotal is number && data.discountTotal >= 0)) &&
             (!('amountPaid' in data) || (data.amountPaid is number && data.amountPaid >= 0)) &&
             (!('amountDue' in data) || (data.amountDue is number && data.amountDue >= 0)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 5000)) &&
             (!('terms' in data) || (data.terms is string && data.terms.size() <= 5000)) &&
             (!('customerEmail' in data) || (data.customerEmail is string && data.customerEmail.size() <= 320)) &&
             (!('customerAddress' in data) || (data.customerAddress is string && data.customerAddress.size() <= 1000)) &&
             (!('customerTaxId' in data) || (data.customerTaxId is string && data.customerTaxId.size() <= 64)) &&
             (!('customerCountry' in data) || (data.customerCountry is string && data.customerCountry.size() <= 100)) &&
             (!('orderId' in data) || (data.orderId is string && data.orderId.size() <= 128));
    }

    // --- Rules ---

    // 1. Users
    match /users/{userId} {
      allow read: if isPlatformAdmin() || (
        isSignedIn() && (
          request.auth.uid == userId ||
          (
            resource != null &&
            resource.data.currentCompanyId is string &&
            isMember(resource.data.currentCompanyId)
          )
        )
      );
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Platform Admin records
    match /platformAdmins/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || hasPlatformAdminClaim());
      // Client-side writes are blocked. Provision this collection from the
      // Firebase console, Admin SDK, or secure server tooling.
      allow create, update, delete: if false;
    }

    // Platform-only operational overlay for tenant control. This is intentionally
    // separate from companies/subscription so Super Admin can manage internal
    // workflows without mutating customer-facing contracts.
    match /platformCompanyControls/{companyId} {
      allow read: if isPlatformAdmin();
      allow create, update: if isPlatformAdmin() &&
                            request.resource.data.companyId == companyId;
      allow delete: if false;
    }

    match /companyStats/{companyId} {
      allow read: if isPlatformAdmin();
      allow create, update: if isPlatformAdmin() &&
                            request.resource.data.companyId == companyId;
      allow delete: if false;
    }

    match /companyBillingStats/{companyId} {
      allow read: if isPlatformAdmin();
      // Billing stats are written by secure backend syncs, not by clients.
      allow create, update, delete: if false;
    }

    match /platformAuditLogs/{logId} {
      allow read: if isPlatformAdmin();
      allow create: if isPlatformAdmin() &&
                    request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /adminAuditLogs/{logId} {
      allow read: if isPlatformAdmin();
      allow create: if isPlatformAdmin() &&
                    request.resource.data.adminUid == request.auth.uid &&
                    request.resource.data.action is string;
      allow update, delete: if false;
    }

    match /feedback/{feedbackId} {
      allow read: if isPlatformAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isEmailVerified() && isValidFeedback(incoming());
      allow update: if isPlatformAdmin() &&
                    incoming().userId == existing().userId &&
                    incoming().companyId == existing().companyId &&
                    incoming().companyName == existing().companyName &&
                    incoming().userEmail == existing().userEmail &&
                    incoming().type == existing().type &&
                    incoming().message == existing().message &&
                    incoming().route == existing().route &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().status in ['open', 'reviewed', 'resolved'];
      allow delete: if false;
    }

    match /betaFeedback/{feedbackId} {
      allow create: if isSignedIn() &&
                    isEmailVerified() &&
                    isValidBetaFeedbackCreate(request.resource.data) &&
                    isMember(request.resource.data.companyId);

      allow read: if isPlatformAdmin();

      allow update: if isPlatformAdmin() &&
                    request.resource.data.companyId == resource.data.companyId &&
                    request.resource.data.userId == resource.data.userId &&
                    request.resource.data.userEmail == resource.data.userEmail &&
                    request.resource.data.title == resource.data.title &&
                    request.resource.data.message == resource.data.message &&
                    request.resource.data.pagePath == resource.data.pagePath &&
                    request.resource.data.type == resource.data.type &&
                    request.resource.data.severity == resource.data.severity &&
                    request.resource.data.status in ['open', 'reviewed', 'resolved'];

      allow delete: if false;
    }

    // 0.2 Test connection
    match /test/connection {
      allow read: if isSignedIn();
    }

    // 2. Memberships
    match /memberships/{membershipId} {
      // Allow user to see their own membership OR admins to see all in company
      allow read: if isPlatformAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        hasRole(resource.data.companyId, ['owner', 'admin'])
      ));
      
      // Create: user linking themselves to a company (during onboarding/invite acceptance)
      allow create: if isSignedIn() && isEmailVerified() && isValidMembership(incoming()) && (
        // Case A: User is the owner of the company being created (Onboarding)
        getAfter(/databases/$(database)/documents/companies/$(incoming().companyId)).data.ownerId == request.auth.uid ||
        // Case B: User was invited and invitation is accepted
        (
          exists(/databases/$(database)/documents/invitations/$(request.auth.token.email + '_' + incoming().companyId)) &&
          getAfter(/databases/$(database)/documents/invitations/$(request.auth.token.email + '_' + incoming().companyId)).data.status == 'accepted'
        )
      );

      // Update: only owners/admins can change roles
      allow update: if isSignedIn() &&
        hasRole(existing().companyId, ['owner', 'admin']) &&
        incoming().userId == existing().userId &&
        incoming().companyId == existing().companyId &&
        // Only an existing owner can promote anyone to owner OR demote an owner.
        (incoming().role == 'owner' ? hasRole(existing().companyId, ['owner']) : true) &&
        (existing().role == 'owner' && incoming().role != 'owner' ? hasRole(existing().companyId, ['owner']) : true) &&
        incoming().updatedAt == request.time &&
        incoming().diff(existing()).affectedKeys().hasOnly(['role', 'updatedAt']);

      // Delete: only owners/admins can delete
      allow delete: if isSignedIn() && 
        hasRole(existing().companyId, ['owner', 'admin']) &&
        (existing().role == 'owner' ? hasRole(existing().companyId, ['owner']) : true);
    }

    // 3. Companies
    match /companies/{companyId} {
      allow read: if isPlatformAdmin() || isMember(companyId);
      // The new owner must match the caller, and any subscription field must be 'starter'.
      // Updates to subscription.planId are reserved for the server (admin SDK / webhook).
      allow create: if isSignedIn() && isEmailVerified() && isValidNewCompany(incoming());
      allow update: if hasRole(companyId, ['owner', 'admin']) &&
                    incoming().ownerId == existing().ownerId &&
                    // Block client-side subscription tampering (planId/status/currentPeriodEnd).
                    (!('subscription' in incoming().diff(existing()).affectedKeys()));
      allow delete: if hasRole(companyId, ['owner']);
    }

    // 4. Products
    match /products/{productId} {
      allow get: if isPlatformAdmin() || isMember(resource.data.companyId);
      allow list: if isPlatformAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + resource.data.companyId)));
      allow create: if hasRole(incoming().companyId, ['owner', 'admin', 'staff']) && isValidProduct(incoming());
      allow update: if hasRole(existing().companyId, ['owner', 'admin', 'staff']) && 
                    isValidProduct(incoming()) &&
                    incoming().companyId == existing().companyId;
      allow delete: if hasRole(existing().companyId, ['owner', 'admin', 'staff']);
    }

    // 5. Invitations
    match /invitations/{invitationId} {
      allow read: if isSignedIn() && (
        request.auth.token.email.lower() == resource.data.email.lower() ||
        hasRole(resource.data.companyId, ['owner', 'admin'])
      );
      allow create: if hasRole(incoming().companyId, ['owner', 'admin']);
      allow update: if (
        // Acceptance
        (request.auth.token.email == existing().email && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'acceptedAt'])) ||
        // Revoke
        (hasRole(existing().companyId, ['owner', 'admin']) && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
      allow delete: if hasRole(existing().companyId, ['owner', 'admin']);
    }

    // 6. Operational Data (Customers, Orders, Inventory, Activities)
    match /customers/{id} {
      allow get: if isPlatformAdmin() || isMember(resource.data.companyId);
      allow list: if isPlatformAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + resource.data.companyId)));
      allow create: if hasRole(incoming().companyId, ['owner', 'admin', 'staff']) && isValidCustomer(incoming());
      allow update: if hasRole(existing().companyId, ['owner', 'admin', 'staff']) && 
                    isValidCustomer(incoming()) &&
                    incoming().companyId == existing().companyId;
      allow delete: if hasRole(existing().companyId, ['owner', 'admin']);
    }

    match /reminders/{id} {
      allow get: if isPlatformAdmin() || isMember(resource.data.companyId);
      allow list: if isPlatformAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + resource.data.companyId)));
      allow create: if hasRole(incoming().companyId, ['owner', 'admin', 'staff']) && isValidReminder(incoming());
      allow update: if hasRole(existing().companyId, ['owner', 'admin', 'staff']) && 
                    isValidReminder(incoming()) &&
                    incoming().companyId == existing().companyId;
      allow delete: if hasRole(existing().companyId, ['owner', 'admin', 'staff']);
    }

    match /customerMessages/{id} {
      allow get: if isPlatformAdmin() || isMember(resource.data.companyId);
      allow list: if isPlatformAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + resource.data.companyId)));
      allow create: if hasRole(incoming().companyId, ['owner', 'admin', 'staff']) && isValidCustomerMessage(incoming());
      allow update: if hasRole(existing().companyId, ['owner', 'admin', 'staff']) && 
                    isValidCustomerMessage(incoming()) &&
                    incoming().companyId == existing().companyId;
      allow delete: if hasRole(existing().companyId, ['owner', 'admin', 'staff']);
    }

    match /orders/{id} {
      allow get: if isPlatformAdmin() || isMember(resource.data.companyId);
      allow list: if isPlatformAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + resource.data.companyId)));
      allow create: if hasRole(incoming().companyId, ['owner', 'admin', 'staff']);
      // Block cross-tenant moves: companyId must remain identical on update.
      // createdAt and ownerId-equivalent fields are also immutable.
      allow update: if hasRole(existing().companyId, ['owner', 'admin', 'staff']) &&
                    incoming().companyId == existing().companyId &&
                    (!('createdAt' in incoming().diff(existing()).affectedKeys()));
      allow delete: if hasRole(existing().companyId, ['owner', 'admin']);
    }
    
    match /orders/{orderId}/items/{itemId} {
      allow read: if isMember(get(/databases/$(database)/documents/orders/$(orderId)).data.companyId);
      allow write: if hasRole(get(/databases/$(database)/documents/orders/$(orderId)).data.companyId, ['owner', 'admin', 'staff']);
    }

    match /inventoryMovements/{id} {
      allow read: if isPlatformAdmin() || isMember(resource.data.companyId);
      allow create: if hasRole(incoming().companyId, ['owner', 'admin', 'staff']);
    }

    match /cashSessions/{id} {
      allow get: if isPlatformAdmin() || isMember(resource.data.companyId);
      allow list: if isPlatformAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + resource.data.companyId)));
      allow create: if hasRole(incoming().companyId, ['owner', 'admin', 'staff']);
      allow update: if hasRole(existing().companyId, ['owner', 'admin', 'staff']) &&
                    incoming().companyId == existing().companyId;
      allow delete: if hasRole(existing().companyId, ['owner', 'admin']);
    }

    match /activities/{id} {
      allow read: if isPlatformAdmin() || isMember(resource.data.companyId);
      allow create: if isMember(incoming().companyId) || isMemberAfter(incoming().companyId);
    }
    
    match /aiInsights/{insightId} {
      allow read: if isPlatformAdmin() || hasRole(resource.data.companyId, ['owner', 'admin']);
      allow write: if false; // System only
    }

    match /stockAlerts/{id} {
      allow read: if isPlatformAdmin() || isMember(resource.data.companyId);
      allow create: if hasRole(incoming().companyId, ['owner', 'admin', 'staff']);
      allow update: if hasRole(existing().companyId, ['owner', 'admin', 'staff']);
      allow delete: if hasRole(existing().companyId, ['owner', 'admin']);
    }

    // Invoices — commercial-grade billing documents. Numbering, status
    // transitions and immutability of company/invoiceNumber are enforced here
    // so the document remains trustworthy once issued.
    match /invoices/{invoiceId} {
      allow get: if isPlatformAdmin() || isMember(resource.data.companyId);
      allow list: if isPlatformAdmin() ||
                  (isSignedIn() && exists(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + resource.data.companyId)));

      // Drafts only at creation. Server / transaction promotes to "issued"
      // afterwards. Company members with edit privileges can create.
      allow create: if hasRole(incoming().companyId, ['owner', 'admin', 'staff']) &&
                    incoming().companyId is string &&
                    incoming().status == 'draft' &&
                    incoming().type in ['invoice', 'quote', 'receipt', 'sales_note'] &&
                    incoming().createdBy == request.auth.uid &&
                    isValidInvoicePayload(incoming());

      // Updates: companyId never moves. Once a doc leaves "draft", line items
      // and totals are frozen — only payment + status transitions and notes
      // can be touched. Cancellation is allowed from any non-terminal state.
      allow update: if hasRole(existing().companyId, ['owner', 'admin', 'staff']) &&
                    incoming().companyId == existing().companyId &&
                    incoming().createdBy == existing().createdBy &&
                    (
                      // Draft → free edits, but bounded payload and never
                      // change createdAt.
                      (existing().status == 'draft' && isValidInvoicePayload(incoming()))
                      ||
                      // Issued / sent / overdue → restricted: only status,
                      // payment fields, notes/terms, pdfUrl/pdfPath and
                      // updatedAt may change. invoiceNumber/series/items
                      // remain locked.
                      (
                        existing().status in ['issued', 'sent', 'overdue'] &&
                        incoming().invoiceNumber == existing().invoiceNumber &&
                        incoming().series == existing().series &&
                        incoming().sequentialNumber == existing().sequentialNumber &&
                        incoming().total == existing().total &&
                        incoming().subtotal == existing().subtotal &&
                        incoming().taxTotal == existing().taxTotal &&
                        incoming().status in ['issued', 'sent', 'paid', 'overdue', 'cancelled']
                      )
                    );

      // Only drafts can be deleted, and only by owner/admin.
      allow delete: if existing().status == 'draft' &&
                    hasRole(existing().companyId, ['owner', 'admin']);
    }

    // Invoice numbering counters — read by company members for visibility,
    // written by company staff via Firestore transactions during "issue".
    // The counter doc id is `${companyId}_${series}` and must keep that link.
    match /invoiceCounters/{counterId} {
      allow read: if isPlatformAdmin() ||
                  (resource != null && isMember(resource.data.companyId));
      allow create: if hasRole(incoming().companyId, ['owner', 'admin', 'staff']) &&
                    counterId == incoming().companyId + '_' + incoming().series &&
                    incoming().nextNumber is number &&
                    incoming().nextNumber >= 1;
      allow update: if hasRole(existing().companyId, ['owner', 'admin', 'staff']) &&
                    incoming().companyId == existing().companyId &&
                    incoming().series == existing().series &&
                    incoming().nextNumber is number &&
                    incoming().nextNumber > existing().nextNumber;
      allow delete: if false;
    }

    match /agentConversations/{conversationId} {
      allow read: if isSignedIn() && (
        isPlatformAdmin() ||
        (resource.data.userId == request.auth.uid && isMember(resource.data.companyId))
      );
      allow create: if isSignedIn() &&
        incoming().userId == request.auth.uid &&
        isMember(incoming().companyId) &&
        incoming().agentName == 'peppy';
      allow update: if isSignedIn() &&
        existing().userId == request.auth.uid &&
        isMember(existing().companyId) &&
        incoming().userId == existing().userId &&
        incoming().companyId == existing().companyId;
      allow delete: if false;
    }
  }
}
