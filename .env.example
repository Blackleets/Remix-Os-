# Backend only. Do not prefix with VITE_.
GEMINI_API_KEY=

# APP_URL: public base URL where the app is hosted.
APP_URL="MY_APP_URL"

# REQUIRED on Vercel / serverless — JSON.stringify of the Firebase service account credentials.
# Without this in serverless runtimes, /api/health returns 503 and all authenticated API routes
# fail with code FIREBASE_ADMIN_NOT_CONFIGURED. Generate at: Firebase Console > Project Settings > Service accounts.
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_PROJECT_ID=
# Optional override for non-default Firestore databases. If unset, falls back to firebase-applet-config.json.
FIREBASE_FIRESTORE_DATABASE_ID=

# Stripe: required for live subscriptions.
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Monthly recurring Stripe price IDs
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=

# Firebase App Check (anti-abuse). OPTIONAL — the app runs fine without it.
# When set, a reCAPTCHA v3 token is attached to Firestore/Storage/Auth calls.
# Register a reCAPTCHA v3 site key in Firebase Console > App Check, enforce it
# per service, then set this. Leave empty to keep App Check disabled.
VITE_RECAPTCHA_SITE_KEY=
# Set to "true" only for local debugging; register the printed debug token
# in the Firebase console. Never enable in production.
VITE_APPCHECK_DEBUG=
