# GEMINI_API_KEY: required for Copilot and AI insights.
# Server-only. Never expose it to the client bundle.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: public base URL where the app is hosted.
APP_URL="MY_APP_URL"

# Firebase Admin access for backend/createApp.ts
# Provide either a JSON stringified service account or runtime/project access.
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_PROJECT_ID=

# Stripe: required for live subscriptions.
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Monthly recurring Stripe price IDs
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=
