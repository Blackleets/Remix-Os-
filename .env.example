# Backend only. Do not prefix with VITE_.
GEMINI_API_KEY=

# APP_URL: public base URL where the app is hosted.
APP_URL="MY_APP_URL"

# Required for Firebase Admin in serverless production if project config file is not available.
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_PROJECT_ID=

# Stripe: required for live subscriptions.
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Monthly recurring Stripe price IDs
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=
